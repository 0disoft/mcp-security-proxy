{
  "name": "@0disoft/mcp-security-proxy-cli",
  "description": "Deny-by-default local stdio proxy and policy inspection CLI for MCP servers.",
  "version": "0.2.0-alpha.4",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/0disoft/mcp-security-proxy.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/0disoft/mcp-security-proxy#readme",
  "bugs": {
    "url": "https://github.com/0disoft/mcp-security-proxy/issues"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "bin": {
    "mcp-security-proxy": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm --filter @0disoft/mcp-security-proxy-runtime build && vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@0disoft/openfeature-local-provider": "1.0.0",
    "@0disoft/mcp-security-proxy-contracts": "workspace:*",
    "@0disoft/mcp-security-proxy-core": "workspace:*",
    "@0disoft/mcp-security-proxy-runtime": "workspace:*",
    "@openfeature/server-sdk": "1.22.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
