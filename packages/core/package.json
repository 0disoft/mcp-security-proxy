{
  "name": "@0disoft/mcp-security-proxy-core",
  "description": "IO-free policy evaluation, classification, redaction, and audit helpers for MCP Security Proxy.",
  "version": "0.2.0-alpha.1",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/0disoft/mcp-security-proxy.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/0disoft/mcp-security-proxy#readme",
  "bugs": {
    "url": "https://github.com/0disoft/mcp-security-proxy/issues"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm --filter @0disoft/mcp-security-proxy-contracts build && vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@0disoft/mcp-security-proxy-contracts": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
