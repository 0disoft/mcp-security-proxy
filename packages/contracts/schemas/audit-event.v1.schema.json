{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0disoft.github.io/mcp-security-proxy/schemas/audit-event.v1.schema.json",
  "title": "MCP Security Proxy Audit Event v1",
  "type": "object",
  "required": ["schemaVersion", "kind", "profileId", "decision", "redaction"],
  "properties": {
    "schemaVersion": { "const": "msp.audit-event.v1" },
    "kind": {
      "enum": ["method-denied", "discovery-filtered", "call-decision", "error"]
    },
    "profileId": { "type": "string" },
    "toolName": { "type": "string" },
    "method": { "type": "string" },
    "decision": { "$ref": "decision.v1.schema.json" },
    "redaction": {
      "type": "object",
      "required": ["applied", "counts"],
      "properties": {
        "applied": { "type": "boolean" },
        "counts": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      },
      "additionalProperties": false
    },
    "correlation": { "$ref": "#/$defs/correlation" }
  },
  "additionalProperties": false,
  "$defs": {
    "correlation": {
      "type": "object",
      "required": [
        "correlationVersion",
        "sessionId",
        "sequence",
        "direction",
        "transport",
        "transportEventId",
        "jsonRpcIdType",
        "discoveryGeneration"
      ],
      "properties": {
        "correlationVersion": { "const": "msp.audit-correlation.v2" },
        "sessionId": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 1 },
        "direction": {
          "enum": ["client_to_upstream", "upstream_to_client", "server_origin", "runtime"]
        },
        "transport": { "const": "stdio" },
        "transportEventId": { "type": "string", "minLength": 1 },
        "jsonRpcIdHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "jsonRpcIdType": { "enum": ["string", "number", "null", "absent"] },
        "method": { "type": "string", "minLength": 1 },
        "matchedRequestMethod": { "type": "string", "minLength": 1 },
        "discoveryGeneration": { "type": "integer", "minimum": 0 },
        "pendingAgeMs": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
        "durationMs": { "type": "integer", "minimum": 0, "maximum": 2147483647 }
      },
      "additionalProperties": false
    }
  }
}
