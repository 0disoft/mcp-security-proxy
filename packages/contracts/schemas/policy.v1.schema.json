{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0disoft.github.io/mcp-security-proxy/schemas/policy.v1.schema.json",
  "title": "MCP Security Proxy Policy v1",
  "type": "object",
  "required": ["schemaVersion", "defaultAction", "methodPolicy", "profiles"],
  "properties": {
    "schemaVersion": { "const": "msp.policy.v1" },
    "defaultAction": { "const": "deny" },
    "methodPolicy": {
      "type": "object",
      "required": ["allowedMethods", "denyUnsupported"],
      "properties": {
        "allowedMethods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["initialize", "notifications/initialized", "ping", "tools/list", "tools/call"]
          }
        },
        "denyUnsupported": { "const": true }
      },
      "additionalProperties": false
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/profile" }
    },
    "redaction": {
      "type": "object",
      "required": ["detectors"],
      "properties": {
        "detectors": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/redactionDetector" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "profile": {
      "type": "object",
      "required": ["id", "defaultAction", "rules", "audit"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "defaultAction": { "const": "deny" },
        "rules": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/rule" }
        },
        "audit": { "$ref": "#/$defs/auditPolicy" }
      },
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "required": ["id", "action"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "action": { "enum": ["allow", "deny", "approval_required"] },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "file-read",
              "file-write",
              "shell",
              "network",
              "secret",
              "database",
              "browser",
              "workflow",
              "unknown"
            ]
          }
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["tools/call"] }
        },
        "paths": { "$ref": "#/$defs/pathRule" },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/commandRule" }
        },
        "networks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/networkRule" }
        },
        "secrets": { "$ref": "#/$defs/secretRule" }
      },
      "anyOf": [
        { "required": ["tools"] },
        { "required": ["capabilities"] },
        { "required": ["methods"] },
        { "required": ["paths"] },
        { "required": ["commands"] },
        { "required": ["networks"] },
        { "required": ["secrets"] }
      ],
      "additionalProperties": false
    },
    "pathRule": {
      "type": "object",
      "properties": {
        "allowedRoots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "deniedRoots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "anyOf": [{ "required": ["allowedRoots"] }, { "required": ["deniedRoots"] }],
      "additionalProperties": false
    },
    "commandRule": {
      "type": "object",
      "required": ["executable"],
      "properties": {
        "executable": { "type": "string", "minLength": 1 },
        "argv": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "networkRule": {
      "type": "object",
      "properties": {
        "domains": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "ips": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "anyOf": [{ "required": ["domains"] }, { "required": ["ips"] }],
      "additionalProperties": false
    },
    "secretRule": {
      "type": "object",
      "required": ["labels"],
      "properties": {
        "labels": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "auditPolicy": {
      "type": "object",
      "required": ["destination", "onFailure", "includeRawArguments", "includeFullPaths"],
      "properties": {
        "destination": { "enum": ["file", "stdout"] },
        "path": { "type": "string", "minLength": 1 },
        "onFailure": { "enum": ["fail_closed", "warn_and_continue"] },
        "includeRawArguments": { "const": false },
        "includeFullPaths": { "type": "boolean" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "destination": { "const": "file" } }, "required": ["destination"] },
          "then": { "required": ["path"] }
        },
        {
          "if": { "properties": { "destination": { "const": "stdout" } }, "required": ["destination"] },
          "then": { "not": { "required": ["path"] } }
        }
      ]
    },
    "redactionDetector": {
      "type": "object",
      "required": ["id", "kind", "replacement"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["secret_like", "environment_value", "path", "prompt"] },
        "replacement": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
