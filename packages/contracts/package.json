{
  "name": "@0disoft/mcp-security-proxy-contracts",
  "description": "Policy, decision, audit, and validation contracts for MCP Security Proxy.",
  "version": "0.2.0-alpha.3",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/0disoft/mcp-security-proxy.git",
    "directory": "packages/contracts"
  },
  "homepage": "https://github.com/0disoft/mcp-security-proxy#readme",
  "bugs": {
    "url": "https://github.com/0disoft/mcp-security-proxy/issues"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
