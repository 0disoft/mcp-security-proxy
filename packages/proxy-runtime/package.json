{
  "name": "@0disoft/mcp-security-proxy-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm --filter @0disoft/mcp-security-proxy-contracts build && pnpm --filter @0disoft/mcp-security-proxy-core build && pnpm --filter @0disoft/mcp-security-proxy-mcp-adapter build && vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@0disoft/mcp-security-proxy-contracts": "workspace:*",
    "@0disoft/mcp-security-proxy-core": "workspace:*",
    "@0disoft/mcp-security-proxy-mcp-adapter": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
